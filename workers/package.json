{
    "name": "@nori-zk/workers",
    "version": "0.0.4",
    "description": "An abstraction to enable workers which operate on node and the browser.",
    "author": "Jonathan Kelsey",
    "license": "Apache-2.0",
    "keywords": [
        "workers"
    ],
    "publishConfig": {
        "registry": "https://registry.npmjs.org/",
        "access": "public"
    },
    "type": "module",
    "main": "build/src/index.js",
    "types": "build/src/index.d.ts",
    "exports": {
        ".": "./build/src/index.js",
        "./node/parent": {
            "import": "./build/src/parent/index.node.js"
        },
        "./node/child": {
            "import": "./build/src/child/index.node.js"
        },
        "./browser/parent": {
            "import": "./build/src/parent/index.browser.js"
        },
        "./browser/child": {
            "import": "./build/src/child/index.browser.js"
        }
    },
    "scripts": {
        "clean": "rimraf build",
        "build": "npm run clean && tsc",
        "buildw": "tsc --watch",
        "coverage": "node ../node_modules/jest/bin/jest.js --coverage",
        "format": "prettier --check --ignore-unknown **/*",
        "format:fix": "prettier --write --ignore-unknown **/*",
        "test": "npm run build && node --experimental-vm-modules ../node_modules/jest/bin/jest.js",
        "testw": "node ../node_modules/jest/bin/jest.js --watch",
        "lint": "npx eslint src/*",
        "lint:fix": "npx eslint src/* --fix"
    },
    "devDependencies": {
        "@babel/preset-env": "^7.29.0",
        "@babel/preset-typescript": "^7.28.5",
        "@nomicfoundation/hardhat-toolbox": "^6.1.0",
        "@nori-zk/pts-types": "5.0.0",
        "@types/jest": "^30.0.0",
        "@typescript-eslint/eslint-plugin": "^8.55.0",
        "@typescript-eslint/parser": "^8.55.0",
        "eslint": "^9.39.2",
        "eslint-plugin-o1js": "^0.4.0",
        "jest": "^30.2.0",
        "npm-workspaces-publish-tool": "^0.0.14",
        "prettier": "^3.8.1",
        "rimraf": "^6.1.2",
        "ts-jest": "^29.4.6",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.55.0"
    },
    "engines": {
        "node": ">=18.14.0"
    },
    "dependencies": {
        "esm-iso-logger": "1.0.2"
    }
}
