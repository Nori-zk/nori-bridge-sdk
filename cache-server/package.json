{
    "name": "@nori-zk/cache-server",
    "version": "0.0.3",
    "description": "",
    "author": "",
    "license": "Apache-2.0",
    "keywords": [
        "server"
    ],
    "type": "module",
    "private": "true",
    "main": "target/src/index.js",
    "types": "target/src/index.d.ts",
    "publishConfig": {
        "registry": "https://registry.npmjs.org/",
        "access": "public"
    },
    "scripts": {
        "clean": "rimraf target",
        "build": "npm run clean && tsc",
        "build:cache": "cd ../contracts/mina/token-bridge/ && npm run build:cache-layouts",
        "serve": "npm run build && node target/src/bin/server.js",
        "lint": "npx eslint src/*",
        "lint:fix": "npx eslint src/* --fix",
        "format": "prettier --check --ignore-unknown **/*",
        "format:fix": "prettier --write --ignore-unknown **/*"
    },
    "exports": {
        ".": "./target/src/index.js"
    },
    "devDependencies": {
        "@babel/preset-env": "^7.29.0",
        "@babel/preset-typescript": "^7.28.5",
        "@types/jest": "^30.0.0",
        "@typescript-eslint/eslint-plugin": "^8.55.0",
        "@typescript-eslint/parser": "^8.55.0",
        "eslint": "^9.39.2",
        "eslint-plugin-o1js": "^0.4.0",
        "jest": "^30.2.0",
        "npm-workspaces-publish-tool": "0.0.17",
        "prettier": "^3.8.1",
        "rimraf": "^6.1.2",
        "ts-jest": "^29.4.6",
        "ts-node": "^10.9.2",
        "typescript": "^5.9.3",
        "typescript-eslint": "^8.55.0",
        "uWebSockets.js": "github:uNetworking/uWebSockets.js#v20.57.0"
    },
    "peerDependencies": {
        "o1js": "2.12.0"
    },
    "engines": {
        "node": ">=18.14.0"
    },
    "dependencies": {
        "@nori-zk/ethprocessor": "*",
        "@nori-zk/mina-token-bridge": "*",
        "@nori-zk/o1js-zk-utils": "*",
        "esm-iso-logger": "1.0.2"
    }
}
