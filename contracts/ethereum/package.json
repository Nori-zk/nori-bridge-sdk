{
    "name": "@nori-zk/ethereum-token-bridge",
    "version": "0.0.10",
    "description": "NoriTokenBridge contract",
    "main": "build/index.js",
    "publishConfig": {
        "registry": "https://registry.npmjs.org/",
        "access": "public"
    },
    "type": "module",
    "scripts": {
        "build": "mkdir -p lib && (test -d lib/aligned_layer || git clone https://github.com/yetanotherco/aligned_layer --recursive lib/aligned_layer) && ETH_NETWORK=hardhat npm run clean && ETH_NETWORK=hardhat hardhat compile && tsc -p tsconfig.package.json",
        "test": "ETH_NETWORK=hardhat hardhat test",
        "test-ci": "ETH_NETWORK=hardhat hardhat test",
        "clean": "hardhat clean",
        "deploy": "dotenv -e .env -- sh -c 'npx hardhat run bin/deploy.ts --network $ETH_NETWORK'",
        "withdraw": "dotenv -e .env -- sh -c 'npx hardhat --network $ETH_NETWORK withdrawAll \"$@\"' --",
        "test:lock": "dotenv -e .env -- sh -c 'npx hardhat --network $ETH_NETWORK lockTokens \"$@\"' --",
        "test:lock-loop": "dotenv -e .env -- sh -c 'while true; do npx hardhat --network \"$ETH_NETWORK\" lockTokens \"$@\" || break; sleep 384; done' --",
        "get-deposited": "dotenv -e .env -- sh -c 'npx hardhat --network $ETH_NETWORK getTotalDeposited \"$@\"' --"
    },
    "author": "",
    "license": "MIT",
    "devDependencies": {
        "@nomicfoundation/hardhat-ethers": "^4.0.1",
        "@nomicfoundation/hardhat-ethers-chai-matchers": "^3.0.0",
        "@nomicfoundation/hardhat-toolbox-mocha-ethers": "^3.0.0",
        "@nomicfoundation/hardhat-typechain": "^3.0.0",
        "@nomicfoundation/hardhat-viem": "^3.0.0",
        "hardhat": "^3.1.11",
        "dotenv": "^17.2.4",
        "chai": "^5.1.2",
        "dotenv-cli": "^8.0.0",
        "npm-workspaces-publish-tool": "0.0.17",
        "typechain": "^8.3.2"
    },
    "files": [
        "build/",
        "package.json",
        "README.md"
    ]
}